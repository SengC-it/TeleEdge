# Paper mode is intentionally fixed. This service never submits exchange orders.
PAPER_EQUITY_USDT=10000
HTTP_HOST=127.0.0.1
HTTP_PORT=8787
SCAN_INTERVAL_MINUTES=15
MONITOR_INTERVAL_SECONDS=60
SIGNAL_MAX_AGE_MINUTES=30
BINANCE_REQUEST_CONCURRENCY=5
BINANCE_REQUEST_DELAY_MS=80

# Optional JSON webhook for entry/exit notifications. Leave empty to use the
# durable local outbox only.
NOTIFY_WEBHOOK_URL=

# Set only for deterministic snapshot diagnostics. Production should remain 0.
TELE_OFFLINE=0
